# Copy to .env.local and fill in. .env.local is gitignored — never commit real secrets.

# Supabase project URL — safe to commit, included here as the real default for this project.
SUPABASE_URL=https://jiqoaqmzmvtovimnmbzl.supabase.co

# Publishable (anon) key — safe to commit, used by the app's DB RosterSource at request time.
SUPABASE_ANON_KEY=sb_publishable_JPsqvaeJbAGnX1JzkUGBqA_riP7wR9u

# Service role key — SECRET, never commit. Only needed to run scripts/ingest-espn.mts
# (bypasses RLS-equivalent restrictions for writes). Get it from the Supabase dashboard
# (Project Settings -> API) and put the real value in your local .env.local only.
SUPABASE_SERVICE_ROLE_KEY=

# --- Feature flags (Vercel Flags SDK — lib/flags.ts) ---

# SECRET. Verifies Vercel Toolbar flag overrides + the discovery endpoint
# (app/.well-known/vercel/flags). Generate per environment:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64url'))"
# Also set it in Vercel env (Preview/Production, mark Sensitive).
FLAGS_SECRET=

# Launch gates read by decide() in lib/flags.ts. Unset/anything-but-1 = off.
# SHOW_UNIFORM_PICKER=1 exposes the Phase 7 uniform picker (header jersey button).
SHOW_UNIFORM_PICKER=
